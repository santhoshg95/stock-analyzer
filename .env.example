BULLISH_MIN_NO_OVERNIGHT_GAP_PROBABILITY=95.00
BULLISH_MIN_RELATIVE_STRENGTH_SCORE=55.00
BEARISH_MAX_TECHNICAL_STOP_PERCENT=3.00
BEARISH_MIN_TARGET_BEFORE_ADVERSE_PROBABILITY=55.00
BEARISH_MIN_NO_OVERNIGHT_GAP_PROBABILITY=95.00
BEARISH_MAX_RELATIVE_STRENGTH_PERCENT=0.00
