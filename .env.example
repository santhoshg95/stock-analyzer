# Optional absolute path when the Codex CLI is not on PATH.
CODEX_EXECUTABLE=codex
MARKET_DATA_SOURCE=kite
TRADING_STRATEGY_MODE=both
NEWS_MAX_AGE_HOURS=72
ENTRY_MIN_CLOSE_LOCATION=0.60
ENTRY_NORMAL_EXTENSION_ATR=1.00
ENTRY_MAX_EXTENSION_ATR=1.50
ENTRY_NO_CHASE_EXTENSION_ATR=2.00
BREAKOUT_RETEST_TOLERANCE_ATR=0.25
BREAKOUT_CONSOLIDATION_MAX_RANGE_ATR=0.80
BULLISH_MAX_ADVERSE_MOVE_PERCENT=3.00
BULLISH_MIN_ADVERSE_HOLD_PROBABILITY=70.00
BULLISH_BARRIER_HORIZON_DAYS=5
BULLISH_BARRIER_MINIMUM_SAMPLES=60
BULLISH_INTRADAY_BARRIER_MINIMUM_SAMPLES=30
BULLISH_MAX_TECHNICAL_STOP_PERCENT=3.00
